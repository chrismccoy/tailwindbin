<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/_head') %>
    <title>Tailwind Preview</title>
  </head>
  <body class="bg-surface-50 text-surface-700 min-h-screen flex items-center justify-center p-4 antialiased">
    <div class="w-full max-w-2xl">

      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-xl bg-brand-600 flex items-center justify-center shadow-lg shadow-brand-600/20">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <h1 class="text-3xl font-bold text-surface-800 tracking-tight">Tailwind Preview</h1>
        </div>
        <p class="text-surface-400 text-sm">
          Upload or paste
          <span class="text-brand-500 font-medium">Tailwind CSS</span>
        </p>
      </div>

      <form id="form" method="post" action="/tailwind/create" data-max-bytes="<%= maxBytes %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input id="file-input" type="file" accept=".html,.htm" hidden />
        <input id="content-input" type="hidden" name="content" />

        <div class="bg-white border border-surface-200 rounded-2xl overflow-hidden shadow-xl shadow-surface-200/50">

          <div class="flex border-b border-surface-100">
            <button
              type="button"
              class="tab flex-1 py-3.5 text-sm font-semibold transition-all border-b-2 cursor-pointer border-brand-500 text-brand-600 bg-brand-50/50"
              data-panel="upload"
            >
              Upload File
            </button>
            <button
              type="button"
              class="tab flex-1 py-3.5 text-sm font-semibold transition-all border-b-2 cursor-pointer border-transparent text-surface-400 hover:text-surface-500 hover:bg-surface-50"
              data-panel="tailwind"
            >
              Paste Tailwind
            </button>
          </div>

          <div class="panel" id="panel-upload">
            <div class="p-6">
              <div
                id="dropzone"
                class="border-2 border-dashed rounded-xl p-14 text-center transition-all cursor-pointer border-surface-200 hover:border-brand-300 hover:bg-brand-50/30"
              >
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-50 mb-5">
                  <svg class="w-8 h-8 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                  </svg>
                </div>
                <h2 class="text-base font-semibold text-surface-700 mb-1">
                  Drop your Tailwind file here
                </h2>
                <p class="text-xs text-surface-400">
                  .html or .htm — or click to browse
                </p>
                <div id="file-name" class="mt-4 text-sm font-medium text-emerald-600 break-all hidden"></div>
                <div id="upload-error" class="mt-3 text-sm text-red-500 hidden"></div>
              </div>
            </div>
            <div class="px-6 pb-6 flex gap-3 justify-end">
              <button
                type="button"
                id="browse-btn"
                class="px-5 py-2.5 text-sm font-medium rounded-lg transition-all cursor-pointer bg-white text-surface-600 border border-surface-200 hover:bg-surface-50 hover:border-surface-300 shadow-sm"
              >
                Browse
              </button>
              <button
                type="submit"
                id="upload-submit"
                disabled
                class="px-6 py-2.5 text-sm font-semibold rounded-lg transition-all cursor-pointer bg-brand-600 text-white hover:bg-brand-700 shadow-sm shadow-brand-600/20 disabled:opacity-40 disabled:cursor-not-allowed disabled:shadow-none"
              >
                Upload
              </button>
            </div>
          </div>

          <div class="panel hidden" id="panel-tailwind">
            <div class="p-6">
              <textarea
                id="tailwind-editor"
                placeholder="Paste your Tailwind here..."
                rows="10"
                class="w-full min-h-56 rounded-xl text-sm p-5 outline-none resize-y transition-all bg-surface-50 border border-surface-200 text-surface-700 placeholder:text-surface-300 font-mono focus:border-brand-300 focus:ring-2 focus:ring-brand-100"
              ></textarea>
              <div id="tailwind-error" class="mt-3 text-sm text-red-500 hidden"></div>
            </div>
            <div class="px-6 pb-6 flex justify-end">
              <button
                type="submit"
                id="tailwind-submit"
                disabled
                class="px-6 py-2.5 text-sm font-semibold rounded-lg transition-all cursor-pointer bg-brand-600 text-white hover:bg-brand-700 shadow-sm shadow-brand-600/20 disabled:opacity-40 disabled:cursor-not-allowed disabled:shadow-none"
              >
                Save
              </button>
            </div>
          </div>

        </div>
      </form>

      <p class="text-center mt-8 text-xs text-surface-300">
        Pastes expire after <%= expiryYears %> year<%= expiryYears !== 1 ? "s" : "" %>. Tailwind CDN is injected automatically.
      </p>

    </div>

    <script src="/js/app.js"></script>
  </body>
</html>
