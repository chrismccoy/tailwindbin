<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/_head') %>
    <title>Admin Login — Tailwind Preview</title>
  </head>
  <body class="bg-surface-50 text-surface-700 min-h-screen flex items-center justify-center p-4 antialiased">
    <div class="w-full max-w-sm">

      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-xl bg-brand-600 flex items-center justify-center shadow-lg shadow-brand-600/20">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-surface-800 tracking-tight">Admin Login</h1>
        </div>
        <p class="text-surface-400 text-sm">Tailwind Preview</p>
      </div>

      <div class="bg-white border border-surface-200 rounded-2xl shadow-xl shadow-surface-200/50 p-7">
        <% if (error) { %>
          <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-600">
            <%= error %>
          </div>
        <% } %>

        <form method="post" action="/admin/login">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="space-y-4">
            <div>
              <label for="username" class="block text-sm font-medium text-surface-600 mb-1.5">Username</label>
              <input
                id="username"
                name="username"
                type="text"
                autocomplete="username"
                required
                class="w-full rounded-xl text-sm px-4 py-2.5 outline-none transition-all bg-surface-50 border border-surface-200 text-surface-700 placeholder:text-surface-300 focus:border-brand-300 focus:ring-2 focus:ring-brand-100"
              />
            </div>

            <div>
              <label for="password" class="block text-sm font-medium text-surface-600 mb-1.5">Password</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                class="w-full rounded-xl text-sm px-4 py-2.5 outline-none transition-all bg-surface-50 border border-surface-200 text-surface-700 placeholder:text-surface-300 focus:border-brand-300 focus:ring-2 focus:ring-brand-100"
              />
            </div>
          </div>

          <button
            type="submit"
            class="mt-6 w-full px-6 py-2.5 text-sm font-semibold rounded-lg transition-all cursor-pointer bg-brand-600 text-white hover:bg-brand-700 shadow-sm shadow-brand-600/20"
          >
            Sign in
          </button>
        </form>
      </div>

    </div>
  </body>
</html>
