<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/_head') %>
    <title><%= paste.key %> — Tailwind Preview</title>
  </head>
  <body class="bg-surface-50 text-surface-700 h-screen flex flex-col antialiased">

    <header class="flex items-center justify-between px-5 py-3 border-b border-surface-200 bg-white flex-shrink-0 shadow-sm">
      <div class="flex items-center gap-4 text-sm">
        <a href="/" class="inline-flex items-center gap-1.5 font-semibold text-brand-600 hover:text-brand-700 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          New
        </a>
        <div class="w-px h-4 bg-surface-200"></div>
        <% if (paste.lineCount > 1) { %>
          <span class="text-surface-400"><%= paste.lineCount %> lines</span>
        <% } %>
        <% if (paste.kbSize > 1) { %>
          <span class="text-surface-400"><%= paste.sizeText %></span>
        <% } %>
        <span class="text-surface-400"><%= paste.ttlText %> TTL</span>
      </div>
      <div class="flex items-center gap-1">
        <a
          href="/tailwind/<%= paste.key %>/raw"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg text-surface-500 hover:text-surface-700 hover:bg-surface-100 transition"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
          </svg>
          Source
        </a>
        <a
          href="/tailwind/<%= paste.key %>/preview"
          target="_blank"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg text-surface-500 hover:text-surface-700 hover:bg-surface-100 transition"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
          Open
        </a>
      </div>
    </header>

    <iframe
      src="/tailwind/<%= paste.key %>/preview"
      sandbox="allow-scripts"
      title="Tailwind Preview"
      class="flex-1 w-full border-none bg-white"
    ></iframe>

  </body>
</html>
