<div class="text-center max-w-md">
  <% if (code === 404) { %>
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-red-50 mb-6">
      <svg class="w-10 h-10 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
      </svg>
    </div>
  <% } else { %>
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-amber-50 mb-6">
      <svg class="w-10 h-10 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743" />
      </svg>
    </div>
  <% } %>
  <h1 class="text-6xl font-bold text-surface-800 mb-2"><%= code %></h1>
  <h2 class="text-lg font-semibold text-surface-600 mb-3"><%= heading %></h2>
  <p class="text-sm text-surface-400 mb-8"><%= message %></p>
  <a
    href="/"
    class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded-lg transition-all bg-brand-600 text-white hover:bg-brand-700 shadow-sm shadow-brand-600/20"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
    </svg>
    <%= code === 404 ? "Create a new paste" : "Back to home" %>
  </a>
</div>
